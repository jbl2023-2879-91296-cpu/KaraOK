DB_HOST=localhost
DB_PORT=3306
DB_NAME=karaok_db
DB_USER=karaok_app
DB_PASSWORD=replace-with-a-strong-database-password
JWT_SECRET=replace-with-at-least-32-random-characters
CORS_ORIGINS=http://localhost:*
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7
# Railway's Gunicorn command uses its injected PORT variable. These values are
# only used by `python app.py` during local development.
APP_HOST=127.0.0.1
APP_PORT=5000
FLASK_DEBUG=false
DEV_MODE=false
# Never expose OTPs in production responses.
EXPOSE_REGISTRATION_OTP=false
RATELIMIT_STORAGE_URI=memory://
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=no-reply@example.com
REGISTRATION_OTP_MINUTES=10
PASSWORD_RESET_MINUTES=15
TRUST_PROXY=false
# On Railway, attach a Volume at /app/uploads. The app automatically uses
# RAILWAY_VOLUME_MOUNT_PATH when AUDIO_UPLOAD_DIR is unset.
AUDIO_UPLOAD_DIR=uploads
MAX_AUDIO_BYTES=26214400
