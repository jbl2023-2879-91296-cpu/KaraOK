DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=karaok_db
DB_USER=karaok_app
DB_PASSWORD=replace-with-the-production-database-password

JWT_SECRET=replace-with-a-generated-secret-of-at-least-32-characters
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7

FLASK_DEBUG=false
DEV_MODE=false
EXPOSE_REGISTRATION_OTP=false
TRUST_PROXY=true

# Native Android requests do not use browser CORS. Keep this restricted if a
# Flutter Web client is deployed later.
CORS_ORIGINS=https://139.99.89.112
RATELIMIT_STORAGE_URI=memory://

# Copy the same provider settings used by the existing local backend/.env.
SMTP_HOST=replace-with-smtp-host
SMTP_PORT=587
SMTP_USERNAME=replace-with-smtp-username
SMTP_PASSWORD=replace-with-smtp-app-password-or-api-key
SMTP_FROM=replace-with-verified-sender
REGISTRATION_OTP_MINUTES=10
PASSWORD_RESET_MINUTES=15

AUDIO_UPLOAD_DIR=/var/lib/karaok/uploads
MAX_AUDIO_BYTES=26214400
